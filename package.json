{
  "name": "dw-skills",
  "version": "0.4.0",
  "private": true,
  "description": "Portable spec-to-ship skills for Codex and Claude Code.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "lint": "scripts/lint.sh",
    "lint:fix": "agnix --fix .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "validate:manifests": "scripts/validate-manifests.sh",
    "validate:artifacts": "scripts/validate-artifacts.sh",
    "validate:docs": "scripts/validate-docs.sh",
    "validate:compat": "node scripts/validate-compat.mjs",
    "validate:install": "scripts/validate-install.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "agnix": "^0.33.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.0"
  },
  "engines": {
    "node": ">=24.16.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "agnix"
    ]
  }
}
