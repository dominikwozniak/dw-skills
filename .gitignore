# --- Repo-specific (outside the dw-bootstrap managed block; survives re-runs) ---

# Node / pnpm (CI tooling: agnix, prettier)
node_modules/

# Scratch & personal notes (never published)
/tmp-*.md
/*.local.md
/research.md

# .agents/ is the cross-agent standard skills path AND a shared namespace: track our own dw-*
# skill symlinks (Codex/Copilot/Cursor/Gemini scan .agents/skills/), but ignore vendored externals
# (e.g. the shadcn `improve` skill) and the lockfile — personal, not this repo's product.
/.agents/*
!/.agents/skills
/.agents/skills/*
!/.agents/skills/dw-*
/.claude/skills/
/.claude/worktrees/
/skills-lock.json

# >>> dw-bootstrap managed block >>>
# Personal agent memory & local overrides — never committed.
/CLAUDE.local.md
/.claude/settings.local.json

# Editor / OS scratch.
.DS_Store
*.swp
.vscode/
.idea/
.obsidian/

# NOTE: `.ai/`, `.claude/settings.json`, and `.claude/hooks/` are TRACKED on
