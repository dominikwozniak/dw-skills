{
  "name": "dw-skills",
  "owner": {
    "name": "Dominik Wozniak"
  },
  "metadata": {
    "description": "A personal bucket of Claude Code skills I actually use or share. Install from the marketplace and pick what you need.",
    "version": "0.1.0"
  },
  "plugins": [
    {
      "name": "dw-misc",
      "version": "0.3.7",
      "source": "./plugins/dw-misc",
      "keywords": [
        "bootstrap",
        "setup",
        "scaffold",
        "init",
        "git",
        "commit",
        "pr",
        "handoff",
        "session",
        "context",
        "workflow",
        "doctor",
        "diagnose",
        "health",
        "env",
        "precommit",
        "husky",
        "lint-staged",
        "hooks"
      ],
      "category": "utilities",
      "tags": ["bootstrap", "git", "handoff", "session", "doctor"]
    },
    {
      "name": "dw-planning",
      "version": "0.1.10",
      "source": "./plugins/dw-planning",
      "keywords": ["spec", "plan", "planning", "requirements", "workflow", "sync"],
      "category": "workflow",
      "tags": ["spec", "planning"]
    },
    {
      "name": "dw-quality",
      "version": "0.1.10",
      "source": "./plugins/dw-quality",
      "keywords": [
        "explain",
        "verify",
        "review",
        "conform",
        "fix",
        "prune",
        "tests",
        "quality",
        "diff"
      ],
      "category": "quality",
      "tags": ["explain", "verify", "review"]
    }
  ]
}
